PORT=3000
# Use either MYSQL_* or DB_* variables.
# DB_* matches common shared-hosting panels and may include the port inside DB_HOST.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=shoefit
MYSQL_TABLE_SUFFIX=_shoefit
ADMIN_EMAILS=aniq@mail.com

# Shared-hosting style example:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1:3306
# DB_PORT=3306
# DB_DATABASE=u123456789_example
# DB_USERNAME=u123456789_user
# DB_PASSWORD=your-password
