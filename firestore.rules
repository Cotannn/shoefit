rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdminEmail() {
      return isSignedIn() &&
        request.auth.token.email in ['aniq@mail.com'];
    }

    function hasAdminRole() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'Admin', 'ADMIN'];
    }

    function isAdmin() {
      return isAdminEmail() || hasAdminRole();
    }

    function isStockOnlyDecrease() {
      return isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) &&
        request.resource.data.stock is number &&
        resource.data.stock is number &&
        request.resource.data.stock >= 0 &&
        request.resource.data.stock <= resource.data.stock;
    }

    match /users/{userId} {
      allow create: if isOwner(userId) &&
        (
          request.resource.data.role == 'customer' ||
          (isAdminEmail() && request.resource.data.role in ['admin', 'Admin', 'ADMIN'])
        );
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isAdmin() || (
        isOwner(userId) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.uid == resource.data.uid
      );
      allow delete: if isAdmin();

      match /cart/{cartItemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /favourites/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isStockOnlyDecrease();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() &&
        request.resource.data.orderId == orderId &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.paymentMethod in ['Demo checkout', 'Stripe'] &&
        request.resource.data.paymentStatus == 'paid' &&
        request.resource.data.orderStatus == 'Processing' &&
        request.resource.data.items is list &&
        request.resource.data.totalPrice is number;
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
